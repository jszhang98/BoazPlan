{
  "chat.agent.enabled": true,
  "chat.agent.maxRequests": 15,
  "github.copilot.chat.agent.runTasks": true,
  "chat.mcp.discovery.enabled": {
    "claude-desktop": true,
    "windsurf": true,
    "cursor-global": true,
    "cursor-workspace": true
  },
  "github.copilot.chat.agent.autoFix": true,
  "chat.tools.autoApprove": false,

  // Enable subagent search & custom agents so background delegation is supported
  "github.copilot.chat.searchSubagent.enabled": true,
  "github.copilot.chat.cli.customAgents.enabled": true,
  "github.copilot.chat.organizationCustomAgents.enabled": true,
  "github.copilot.chat.askQuestions.enabled": true,

  // Keep the main chat open after delegation (non-blocking behavior)
  "chat.exitAfterDelegation": false
}