generator client {
  provider = "prisma-client-js"
}

datasource db {
  // using SQLite locally for simple development. When ready for production,
  // update provider to "postgresql" and set DATABASE_URL accordingly (see
  // ../_bmad-output/implementation-artifacts/story-0-3-postgres-migration.md).
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Request {
  id          String   @id @default(uuid())
  title       String
  description String?
  urgency     String   @default("normal")   // normal | high | urgent
  visibility  String   @default("public")   // public | group | private
  status      String   @default("open")     // open | pending_approval | assigned | resolved
  anonymous   Boolean  @default(false)      // when true, authorId is stored but never exposed in responses
  hidden      Boolean  @default(false)      // hidden by a moderator
  churchId    String?
  authorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  church            Church?              @relation(fields: [churchId], references: [id], onDelete: SetNull)
  author            User?                @relation(fields: [authorId], references: [id], onDelete: SetNull)
  assignments       VolunteerAssignment[]
  reports           ContentReport[]
  moderationActions ModerationAction[]
}

// Volunteer assignment lifecycle: pending → accepted | declined | completed
model VolunteerAssignment {
  id          String   @id @default(uuid())
  requestId   String
  volunteerId String
  status      String   @default("pending")  // pending | accepted | declined | completed
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  request     Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  volunteer   User     @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@unique([requestId, volunteerId])
}

model User {
  id                      String                @id @default(uuid())
  email                   String                @unique
  displayName             String?
  phone                   String?               @unique
  verified                Boolean               @default(false)
  verificationCode        String?
  verificationExpiresAt   DateTime?
  notificationPreferences String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  memberships             ChurchMembership[]
  requests                Request[]
  assignments             VolunteerAssignment[]
  reports                 ContentReport[]
  moderationActions       ModerationAction[]
  auditLogs               AuditLog[]
  notifications           Notification[]
  pushSubscriptions       PushSubscription[]
  announcements           Announcement[]
}

model Church {
  id               String             @id @default(uuid())
  name             String
  slug             String             @unique
  location         String?
  privacyMode      String             @default("open")  // "open" | "strict"
  requireApproval  Boolean            @default(false)   // force pending_approval for all posts
  reportThreshold  Int                @default(3)       // auto-hide after N pending reports
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  memberships      ChurchMembership[]
  requests         Request[]
  announcements    Announcement[]
}

// Content report — users flag requests for moderator review
model ContentReport {
  id         String   @id @default(uuid())
  requestId  String
  reporterId String?
  reason     String   // spam | harassment | inappropriate | off-topic | other
  notes      String?
  status     String   @default("pending")  // pending | reviewed | dismissed
  createdAt  DateTime @default(now())

  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  reporter   User?    @relation(fields: [reporterId], references: [id], onDelete: SetNull)
}

// Moderation action taken on a request
model ModerationAction {
  id        String   @id @default(uuid())
  requestId String
  actorId   String?
  action    String   // hide | restore | dismiss_reports | approve
  reason    String
  createdAt DateTime @default(now())

  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
}

// Immutable audit trail for sensitive actions
model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  targetType String   // request | user | church | membership
  targetId   String
  reason     String?
  metadata   String?  // JSON string
  createdAt  DateTime @default(now())

  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
}

// Roles: member | leader | pastor | admin
model ChurchMembership {
  id        String   @id @default(uuid())
  churchId  String
  userId    String
  role      String   @default("member")  // member | leader | pastor | admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([churchId, userId])
}

// In-app notification inbox entry — created for every notification event
model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // assignment_created | assignment_updated | announcement | digest
  title     String
  body      String?
  read      Boolean  @default(false)
  metadata  String?  // JSON — e.g. { requestId, assignmentId, churchId }
  createdAt DateTime @default(now())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Stores a user's Web Push subscription for VAPID-based push notifications
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Church-wide broadcast message created by a pastor or admin
model Announcement {
  id        String   @id @default(uuid())
  churchId  String
  authorId  String?
  title     String
  body      String
  createdAt DateTime @default(now())

  church   Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  author   User?  @relation(fields: [authorId], references: [id], onDelete: SetNull)
}
