{
  "name": "boazplan",
  "version": "0.1.0",
  "description": "BoazPlan - Church mutual aid platform",
  "type": "module",
  "scripts": {
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && npm run dev",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "test:unit": "vitest run apps/api/tests",
    "test:e2e": "playwright test"
  },
  "author": "Jansen",
  "license": "MIT",
  "devDependencies": {
    "vitest": "^1.0.0",
    "playwright": "^1.35.0",
    "@playwright/test": "^1.35.0",
    "concurrently": "^8.2.0"
  }
}